# Generate a unique value before the first run:
# python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=
DEBUG=true
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Public branding. Replace the example operator details on a fork.
SITE_URL=http://127.0.0.1:8000
SITE_AUTHOR=Christopher Vogt
SITE_OWNER_ADDRESS=
CONTACT_EMAIL=contact@example.com

# A dotted callable supplied by your own private strategy package.
# It receives the Django request and returns the documented home-payload dict.
DAXSNACK_HOME_PAYLOAD_PROVIDER=

# SQLite is the zero-configuration default. Set DB_ENGINE=postgresql and the
# remaining DB_* values for PostgreSQL.
DB_ENGINE=sqlite
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Console delivery is safe for local development. Configure SMTP in production.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=daxsnack <contact@example.com>
EMAIL_FROM_NAME=daxsnack
NOTIFY_EMAIL=contact@example.com
EMAIL_TIMEOUT=20

# Optional shared cache used for rate limiting and live snapshots.
RATELIMIT_REDIS_URL=
