# Copy to .env and replace every example value before deployment.
SECRET_KEY=replace-with-a-long-random-value
DEBUG=false
ALLOWED_HOSTS=example.com,www.example.com
CSRF_TRUSTED_ORIGINS=https://example.com

# Public identity and operator details
SITE_NAME=open trading system
SITE_TITLE=Open Trading System
SITE_DESCRIPTION=A self-hostable Django dashboard for publishing operator-provided trading setups.
SITE_URL=https://example.com
SITE_OWNER_NAME=Example Operator
SITE_OWNER_ADDRESS=Example Street 1, Example City, Example Country
CONTACT_EMAIL=contact@example.com

# Optional private strategy/display adapter
TRADING_SYSTEM_HOME_PAYLOAD_PROVIDER=

# Database: sqlite is the safe local default. Set the remaining values for PostgreSQL.
DB_ENGINE=sqlite
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Optional Redis-backed rate limiting
RATELIMIT_REDIS_URL=

# Email: console is the safe default. Production SMTP must use STARTTLS and
# DEFAULT_FROM_EMAIL must contain the same address as EMAIL_HOST_USER.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Open Trading System <contact@example.com>
EMAIL_FROM_NAME=Open Trading System
SUBSCRIBER_LIST_ID=open trading system subscriber alerts <alerts.example.com>
NOTIFY_EMAIL=
EMAIL_TIMEOUT=20

# Presentation and runtime limits
SHOW_ACCOUNT_TOTAL_PERFORMANCE=false
SHOW_EST_ANNUAL_RETURN=false
TRADING_SYSTEM_NUMERIC_THREADS=1

# Optional broker adapter. New live trades remain disabled unless explicitly enabled.
CAPITAL_API_KEY=
CAPITAL_LIVE_NEW_TRADES_ENABLED=false
